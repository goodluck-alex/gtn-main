# Database
# Use your hosted Postgres URL (Render Postgres / Neon / Supabase / etc).
# Keep production credentials only in your platform's Environment Variables UI.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

JWT_SECRET="change-me"

# --- GTN Admin console (separate Next app; /api/admin/*) ---
# Strong secret, different from JWT_SECRET
# ADMIN_JWT_SECRET="change-me-admin-jwt"
# Comma-separated origins allowed to call /api/admin from a browser (CORS)
# Default in code includes http://localhost:3001 if unset
# ADMIN_APP_ORIGINS="http://localhost:3001,https://admin.yourdomain.com"
# Bootstrap first operator — vars below are NOT read by the login API; they are only used when you run a script.
# New admin:  npm run admin:create-user
# New password for existing admin:  npm run admin:reset-password  (same email/password vars)
# ADMIN_BOOTSTRAP_EMAIL=ops@example.com
# ADMIN_BOOTSTRAP_PASSWORD="use-a-long-random-password"
# ADMIN_BOOTSTRAP_NAME=Ops
# ADMIN_BOOTSTRAP_ROLE=superadmin

# --- Plans payments: MTN MoMo Collections + Airtel Money (sandbox first) ---
# MTN MoMo Collections
# MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
# MTN_MOMO_TARGET_ENV=sandbox
# MTN_MOMO_SUBSCRIPTION_KEY=
# MTN_MOMO_API_USER=
# MTN_MOMO_API_KEY=
# MTN_MOMO_CURRENCY=UGX
# MTN_MOMO_CALLBACK_URL=
#
# Airtel Money
# AIRTEL_BASE_URL=https://openapiuat.airtel.africa
# AIRTEL_CLIENT_ID=67b6ea6f-7025-4d2c-869f-cb181add504c
# AIRTEL_CLIENT_SECRET=7d48be4c-b248-442c-a304-12a38c621cb4
# AIRTEL_COUNTRY=UG
# AIRTEL_CURRENCY=UGX

# Payments (global defaults)
# PAYMENT_DEFAULT_CURRENCY=UGX

# Crypto (USDT TRC20)
# USDT_WALLET=TRXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# USDT_TRC20_CONFIRMATIONS=1
# USDT_TRC20_EXPIRES_MIN=60
# USDT_TRC20_LOOKBACK_MIN=120
# TRONGRID_BASE_URL=https://api.trongrid.io
# TRONGRID_API_KEY=

# Card gateway (optional; hosted checkout mode)
# CARD_GATEWAY_ENABLED=false
# APP_BASE_URL=http://localhost:3000

# Phase 9 — Security & Reliability
# Payment API rate limits (per user+IP per minute)
# PAYMENT_RATE_CREATE_PER_MIN=12
# PAYMENT_RATE_INITIATE_PER_MIN=15
# PAYMENT_RATE_CONFIRM_PER_MIN=30
#
# Anti-fraud payment velocity / amount bounds
# PAYMENT_ANTIFRAUD_CREATE_PER_MIN=10
# PAYMENT_MIN_AMOUNT=0.01
# PAYMENT_MAX_AMOUNT=5000
#
# Provider retry/backoff and timeline size
# PAYMENT_RETRY_MAX_ATTEMPTS=3
# PAYMENT_RETRY_BASE_MS=250
# PAYMENT_TIMELINE_MAX_EVENTS=120
#
# Webhook signature HMAC secrets (sha256 over JSON payload)
# PAYMENT_WEBHOOK_SECRET=
# PAYMENT_WEBHOOK_SECRET_MTN=
# PAYMENT_WEBHOOK_SECRET_AIRTEL=
# PAYMENT_WEBHOOK_SECRET_USDT_TRC20=
# PAYMENT_WEBHOOK_SECRET_GATEWAY=
#
# Admin trace endpoint token (x-admin-trace-token header)
# PAYMENT_ADMIN_TRACE_TOKEN=change-me-strong-token

# First subscriberId when Counter row is auto-created (default 691000001)
# SUBSCRIBER_ID_START=691000001

# Referrals: minutes granted once per UTC day on /users/me (default 5). Set 0 to disable.
# DAILY_FREE_MINUTES=5
# Max completed referral signups per referrer per client IP hash per UTC day (fraud cap).
# REFERRAL_MAX_PER_IP_DAY=10
# --- FCM incoming-call push (optional; JSON service account one line) ---
# Firebase Console → Project settings → Service accounts → Generate new private key
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}

# --- P2P voice calls (WebRTC) ---
# Phase 1: strip TURN from ICE_SERVERS_JSON so only STUN is used (set false when TURN is ready).
# WEBRTC_P2P_ONLY=true

# --- WebRTC ICE (STUN first; add TURN URLs + credentials when ready) ---
# Optional JSON array overriding default Google STUN. Example with TURN later:
# ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"u","credential":"p"}]
